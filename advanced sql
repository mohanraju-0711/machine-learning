-- =========================
-- 1. INNER JOIN
-- =========================

SELECT 
    s.name,
    c.course_name,
    e.marks,
    e.semester
FROM Enrollments e
INNER JOIN Students s ON e.student_id = s.student_id
INNER JOIN Courses c ON e.course_id = c.course_id;

-- =========================
-- 2. LEFT JOIN
-- =========================

SELECT 
    s.name,
    f.total_fee,
    f.paid_fee,
    f.total_fee - f.paid_fee AS pending_fee
FROM Students s
LEFT JOIN Fees f ON s.student_id = f.student_id;

-- =========================
-- 3. GROUP BY WITH HAVING
-- =========================

SELECT 
    s.department,
    AVG(e.marks) AS average_marks
FROM Students s
JOIN Enrollments e ON s.student_id = e.student_id
GROUP BY s.department
HAVING AVG(e.marks) > 75;

-- =========================
-- 4. SUBQUERY
-- =========================

SELECT name
FROM Students
WHERE student_id IN (
    SELECT student_id
    FROM Enrollments
    WHERE marks > 85
);

-- =========================
-- 5. CORRELATED SUBQUERY
-- =========================

SELECT 
    s.name,
    e.marks
FROM Students s
JOIN Enrollments e ON s.student_id = e.student_id
WHERE e.marks > (
    SELECT AVG(e2.marks)
    FROM Enrollments e2
    WHERE e2.course_id = e.course_id
);

-- =========================
-- 6. CTE
-- =========================

WITH StudentAverage AS (
    SELECT 
        student_id,
        AVG(marks) AS avg_marks
    FROM Enrollments
    GROUP BY student_id
)
SELECT 
    s.name,
    sa.avg_marks
FROM StudentAverage sa
JOIN Students s ON sa.student_id = s.student_id
WHERE sa.avg_marks > 80;

-- =========================
-- 7. WINDOW FUNCTION - RANK
-- =========================

SELECT 
    s.name,
    c.course_name,
    e.marks,
    RANK() OVER (
        PARTITION BY c.course_name 
        ORDER BY e.marks DESC
    ) AS course_rank
FROM Enrollments e
JOIN Students s ON e.student_id = s.student_id
JOIN Courses c ON e.course_id = c.course_id;

-- =========================
-- 8. WINDOW FUNCTION - RUNNING AVERAGE
-- =========================

SELECT 
    enrollment_id,
    student_id,
    marks,
    AVG(marks) OVER (
        ORDER BY enrollment_id
    ) AS running_average
FROM Enrollments;

-- =========================
-- 9. CASE STATEMENT
-- =========================

SELECT 
    s.name,
    e.marks,
    CASE
        WHEN e.marks >= 90 THEN 'A+'
        WHEN e.marks >= 80 THEN 'A'
        WHEN e.marks >= 70 THEN 'B'
        WHEN e.marks >= 60 THEN 'C'
        ELSE 'Fail'
    END AS grade
FROM Students s
JOIN Enrollments e ON s.student_id = e.student_id;

-- =========================
-- 10. VIEW
-- =========================

CREATE VIEW StudentPerformance AS
SELECT 
    s.student_id,
    s.name,
    s.department,
    AVG(e.marks) AS average_marks
FROM Students s
JOIN Enrollments e ON s.student_id = e.student_id
GROUP BY s.student_id, s.name, s.department;

SELECT * FROM StudentPerformance;

