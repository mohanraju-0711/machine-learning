-- 12. TRIGGER
-- =========================

CREATE TABLE FeeAudit (
    audit_id INT AUTO_INCREMENT PRIMARY KEY,
    student_id INT,
    old_paid_fee DECIMAL(10,2),
    new_paid_fee DECIMAL(10,2),
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

DELIMITER //

CREATE TRIGGER after_fee_update
AFTER UPDATE ON Fees
FOR EACH ROW
BEGIN
    INSERT INTO FeeAudit(student_id, old_paid_fee, new_paid_fee)
    VALUES(OLD.student_id, OLD.paid_fee, NEW.paid_fee);
END //

DELIMITER ;

UPDATE Fees
SET paid_fee = paid_fee + 10000
WHERE student_id = 3;

SELECT * FROM FeeAudit;

-- =========================
-- 13. STORED PROCEDURE
-- =========================

DELIMITER //

CREATE PROCEDURE GetStudentReport(IN sid INT)
BEGIN
    SELECT 
        s.name,
        s.department,
        c.course_name,
        e.marks,
        CASE
            WHEN e.marks >= 90 THEN 'A+'
            WHEN e.marks >= 80 THEN 'A'
            WHEN e.marks >= 70 THEN 'B'
            WHEN e.marks >= 60 THEN 'C'
            ELSE 'Fail'
        END AS grade
    FROM Students s
    JOIN Enrollments e ON s.student_id = e.student_id
    JOIN Courses c ON e.course_id = c.course_id
    WHERE s.student_id = sid;
END //

DELIMITER ;

CALL GetStudentReport(1);

-- =========================
-- 14. FIND TOP STUDENT PER COURSE
-- =========================

WITH RankedStudents AS (
    SELECT 
        s.name,
        c.course_name,
        e.marks,
        RANK() OVER (
            PARTITION BY c.course_id
            ORDER BY e.marks DESC
        ) AS rank_position
    FROM Enrollments e
    JOIN Students s ON e.student_id = s.student_id
    JOIN Courses c ON e.course_id = c.course_id
)
SELECT *
FROM RankedStudents
WHERE rank_position = 1;

-- =========================
-- 15. PENDING FEE REPORT
-- =========================

SELECT 
    s.name,
    f.total_fee,
    f.paid_fee,
    f.total_fee - f.paid_fee AS pending_fee,
    CASE
        WHEN f.total_fee = f.paid_fee THEN 'Paid'
        WHEN f.paid_fee = 0 THEN 'Not Paid'
        ELSE 'Partially Paid'
    END AS payment_status
FROM Students s
JOIN Fees f ON s.student_id = f.student_id;
